@inherits StepEditModal<WaitStep>

<StepEditModalTemplate Modal="this" TStep="WaitStep">
    @if (Step is not null)
    {
        <div class="row mt-3">
            <div class="col-md-4 d-md-flex align-items-center justify-content-end">
                <label class="form-label mb-lg-0">Wait seconds</label>
            </div>
            <div class="col-md-6 d-inline">
                <div class="input-group input-group-sm" style="max-width: 12rem;">
                    <div class="input-group-text">
                        <SvgIcon Icon="LucideIcon.Hourglass" />
                    </div>
                    <InputNumber class="form-control form-control-sm" @bind-Value="Step.WaitSeconds" />
                </div>
            </div>
        </div>
    }
</StepEditModalTemplate>